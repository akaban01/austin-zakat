---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import SectionHeading from "../components/SectionHeading.astro";
import Button from "../components/Button.astro";

const steps = [
  {
    title: "1. Community members give zakat, sadaqah, and Zakat al-Fitr",
    description:
      "Individuals and families across Greater Austin contribute their obligatory zakat, along with sadaqah and seasonal Zakat al-Fitr, directly to a partner masjid.",
  },
  {
    title: "2. Funds are pooled across the committee",
    description:
      "Rather than each masjid collecting and distributing zakat in isolation, GAMRC unites contributions from nine masajid across Austin, Cedar Park, Round Rock, Leander, Pflugerville, Manor, Georgetown, Kyle, and Buda, so help can reach whoever needs it most.",
  },
  {
    title: "3. Applications are reviewed by a GAMRC representative",
    description:
      "Families in need submit one shared application along with supporting documents. A GAMRC representative at their nearest partner masjid follows up with a short interview before a decision is made.",
  },
  {
    title: "4. Assistance is distributed quickly and directly",
    description:
      "Checks are sent directly to the landlord or utility provider rather than as cash, so relief reaches the actual need without delay.",
  },
  {
    title: "5. Ongoing cases receive continued support",
    description:
      "Support for a family typically lasts 6 to 24 months depending on their situation — long enough to help them stand on their own, not just a single gift.",
  },
];

const eligibility = [
  "Have an address in Austin, Cedar Park, Round Rock, Leander, Pflugerville, Manor, Georgetown, Kyle, or Buda",
  "Facing rent, utility, or eviction-related hardship — reach out before a notice is issued",
  "In need of food assistance or Ramadan support",
  "A single mother, widow, divorced, or separated woman (apply through GAMRC's sister organization, MCSS)",
  "Facing an urgent medical expense or unmanageable debt",
];

const costs = [
  { label: "Rent", amount: 1500 },
  { label: "Electricity", amount: 200 },
  { label: "Water", amount: 100 },
  { label: "Clothing", amount: 100 },
  { label: "Grocery / Food", amount: 1000 },
  { label: "Education (annual $8,000)", amount: 667 },
];
const monthlyTotal = costs.reduce((sum, c) => sum + c.amount, 0);
---

<BaseLayout
  title="How It Works"
  description="Learn how GAMRC collects zakat from across Greater Austin and distributes it through partner masajid to families facing rent, food, medical, and other urgent needs."
>
  <PageHero
    eyebrow="How It Works"
    title="A unified committee, so zakat moves faster"
    description="GAMRC coordinates zakat work across Greater Austin's masajid so that giving and receiving happen through one trusted process — one application, one committee, one decision."
  />

  <section class="mx-auto max-w-4xl px-5 py-20">
    <div class="space-y-8">
      {steps.map((step) => (
        <div class="flex gap-5 rounded-2xl border border-emerald-900/8 bg-white/70 p-6 shadow-sm shadow-emerald-950/5">
          <div class="flex-1">
            <h2 class="font-display text-lg tracking-wide text-emerald-950">{step.title}</h2>
            <p class="prose-body mt-2 text-sm leading-relaxed text-emerald-950/70">{step.description}</p>
          </div>
        </div>
      ))}
    </div>
  </section>

  <section id="example-case" class="bg-emerald-50/60 py-20">
    <div class="mx-auto max-w-4xl px-5">
      <SectionHeading eyebrow="A Real Example" title="How much it takes to support a family in Austin" />
      <p class="prose-body mt-5 max-w-2xl text-sm leading-relaxed text-emerald-950/70">
        Austin is an amazing city, but it costs a lot to live here. This burden falls especially
        hard on single mothers and refugee families. A donation of $200&ndash;$300 falls short of
        what most families need to reach lasting stability — here's what one household's minimum
        monthly costs can look like.
      </p>
      <div class="mt-8 overflow-hidden rounded-2xl border border-emerald-900/8 bg-white shadow-sm shadow-emerald-950/5">
        <table class="w-full text-sm">
          <thead class="bg-emerald-800 text-white">
            <tr>
              <th class="px-5 py-3 text-left font-medium">Expense</th>
              <th class="px-5 py-3 text-right font-medium">Monthly Cost</th>
            </tr>
          </thead>
          <tbody>
            {costs.map((c, i) => (
              <tr class:list={[i % 2 === 0 ? "bg-white" : "bg-emerald-50/50"]}>
                <td class="px-5 py-2.5 text-emerald-950/80">{c.label}</td>
                <td class="px-5 py-2.5 text-right text-emerald-950/80">${c.amount.toLocaleString()}</td>
              </tr>
            ))}
          </tbody>
          <tfoot class="bg-gold-100 font-semibold text-emerald-950">
            <tr>
              <td class="px-5 py-3">Total Monthly</td>
              <td class="px-5 py-3 text-right">${monthlyTotal.toLocaleString()}</td>
            </tr>
            <tr>
              <td class="px-5 py-3">Total Annual</td>
              <td class="px-5 py-3 text-right">${(monthlyTotal * 12).toLocaleString()}</td>
            </tr>
          </tfoot>
        </table>
      </div>
    </div>
  </section>

  <section class="py-20">
    <div class="mx-auto max-w-4xl px-5">
      <SectionHeading eyebrow="Who We Help" title="Support for families across Greater Austin" />
      <ul class="prose-body mt-8 space-y-3">
        {eligibility.map((item) => (
          <li class="flex items-start gap-3 text-emerald-950/80">
            <svg class="mt-1 h-4 w-4 flex-shrink-0 text-emerald-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="m5 13 4 4L19 7" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
            {item}
          </li>
        ))}
      </ul>
      <div class="mt-10">
        <Button href="/apply-for-help">Start Your Application</Button>
      </div>
    </div>
  </section>
</BaseLayout>
