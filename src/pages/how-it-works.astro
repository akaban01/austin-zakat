---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import SectionHeading from "../components/SectionHeading.astro";
import Button from "../components/Button.astro";

const steps = [
  {
    title: "1. Community members give zakat, sadaqah, and Zakat al-Fitr",
    description:
      "Individuals and families across Greater Austin contribute their obligatory zakat, along with sadaqah and seasonal Zakat al-Fitr, directly to GAMRC or through a partner masjid.",
  },
  {
    title: "2. Funds are pooled across the committee",
    description:
      "Rather than each masjid collecting and distributing zakat in isolation, GAMRC unites contributions from across Austin, Round Rock, Cedar Park, Pflugerville, Georgetown, Leander, and Lake Travis, so help can reach whoever needs it most — not just wherever the money happened to land.",
  },
  {
    title: "3. Applications are reviewed by trusted volunteers",
    description:
      "Families in need submit an application, which is reviewed by volunteer coordinators at their nearest partner masjid. These are neighbors and community members who understand local circumstances and can verify need with care and discretion.",
  },
  {
    title: "4. Assistance is distributed quickly and directly",
    description:
      "Once a request is verified, funds are directed to the specific need — rent, a utility bill, groceries, or a medical expense — so families get relief without unnecessary delay.",
  },
  {
    title: "5. Ongoing cases receive continued support",
    description:
      "Some situations, like widows, orphans, and single mothers rebuilding after hardship, need more than a single gift. GAMRC and its partner masajid follow up to provide continued support where it's needed.",
  },
];

const eligibility = [
  "Facing rent, utility, or eviction-related hardship",
  "In need of food assistance or Ramadan support",
  "A widow, orphan, or single parent navigating hardship",
  "Affected by domestic violence and in need of a safe transition",
  "Facing an urgent medical expense or unmanageable debt",
];
---

<BaseLayout
  title="How It Works"
  description="Learn how GAMRC collects zakat from across Greater Austin and distributes it through partner masajid to families facing rent, food, medical, and other urgent needs."
>
  <PageHero
    eyebrow="How It Works"
    title="A unified committee, so zakat moves faster"
    description="GAMRC was formed in 2014 to coordinate zakat work across Greater Austin so that giving and receiving happen through one trusted, transparent process — not scattered across disconnected efforts."
  />

  <section class="mx-auto max-w-4xl px-5 py-20">
    <div class="space-y-8">
      {steps.map((step) => (
        <div class="flex gap-5 rounded-2xl border border-emerald-900/8 bg-white/70 p-6 shadow-sm shadow-emerald-950/5">
          <div class="flex-1">
            <h2 class="font-display text-lg tracking-wide text-emerald-950">{step.title}</h2>
            <p class="prose-body mt-2 text-sm leading-relaxed text-emerald-950/70">{step.description}</p>
          </div>
        </div>
      ))}
    </div>
  </section>

  <section class="bg-emerald-50/60 py-20">
    <div class="mx-auto max-w-4xl px-5">
      <SectionHeading eyebrow="Who We Help" title="Support for families across Greater Austin" />
      <ul class="prose-body mt-8 space-y-3">
        {eligibility.map((item) => (
          <li class="flex items-start gap-3 text-emerald-950/80">
            <svg class="mt-1 h-4 w-4 flex-shrink-0 text-emerald-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="m5 13 4 4L19 7" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
            {item}
          </li>
        ))}
      </ul>
      <div class="mt-10">
        <Button href="/apply-for-help">Start Your Application</Button>
      </div>
    </div>
  </section>
</BaseLayout>
