---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import SectionHeading from "../components/SectionHeading.astro";
import ZakatCalculator from "../components/ZakatCalculator.astro";
import Button from "../components/Button.astro";
import { masjidDonationLinks } from "../data/masajid";

const methods = [
  {
    title: "Zelle",
    description: "accountant@austinmosque.org — please specify Zakat or Sadaqah in the memo.",
  },
  {
    title: "Venmo",
    description: "@icgamanor — please specify Zakat or Sadaqah in the memo.",
  },
  {
    title: "Check",
    description: "Make checks payable to ICGA. Mail to: 5110 Manor Rd, Austin, TX 78723.",
  },
  {
    title: "PayPal Giving Fund",
    description: "Donate to the Islamic Center of Greater Austin with no processing fees.",
    href: "https://www.paypal.com/us/fundraiser/charity/1573815",
  },
  {
    title: "Feeling Blessed",
    description: "Give online through the Feeling Blessed donation platform.",
    href: "https://www.feelingblessed.org/donate/islamic-center-of-greater-austin-manor",
  },
  {
    title: "Madina Apps",
    description: "Support GAMRC through the Madina Apps giving platform.",
    href: "https://payments.madinaapps.com/ICGA",
  },
  {
    title: "Company Matching (Benevity)",
    description: "ICGA is registered with several company matching programs — Google, Apple, Visa, Intel, and more. Check with your HR department.",
    href: "https://causes.benevity.org/user",
  },
  {
    title: "Company Matching (AustinCares)",
    description: "512 Brothers & Sisters (DBA AustinCares, EIN 47-0996261) is registered with matching programs including IBM, Microsoft, and Dell.",
    href: "https://causes.benevity.org/user",
  },
  {
    title: "Stock Donations",
    description: "Donate appreciated stock through Nueces Mosque — be sure to select \"Zakat\" on the form.",
    href: "https://www.nuecesmosque.com/reconstruction#donate",
  },
];
---

<BaseLayout
  title="Pay Zakat"
  description="Pay your zakat locally through GAMRC's partner masajid — via Zelle, Venmo, check, PayPal Giving Fund, stock transfer, and more."
>
  <PageHero
    eyebrow="Pay Zakat"
    title="Give with confidence, right here in Austin"
    description="GAMRC is not a separate nonprofit — it's a unified committee of Austin-area masajid. Zakat given below is coordinated through our partner masajid and directed to families across Greater Austin facing real, urgent need."
  />

  <section class="mx-auto max-w-4xl px-5 py-20">
    <SectionHeading eyebrow="Zakat Calculator" title="Estimate what you owe" />
    <p class="prose-body mt-4 text-sm leading-relaxed text-emerald-950/70">
      This calculator uses the silver standard for nisab, a commonly used and more cautious
      threshold. It's meant as a helpful estimate only — for a precise ruling on your specific
      situation, please consult a knowledgeable scholar.
    </p>
    <div class="mt-8">
      <ZakatCalculator />
    </div>
  </section>

  <section class="bg-emerald-50/60 py-20">
    <div class="mx-auto max-w-6xl px-5">
      <SectionHeading eyebrow="Ways to Give" title="Give directly, please mark it Zakat or Sadaqah" />
      <div class="mt-10 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {methods.map((m) => (
          <div class="rounded-2xl border border-emerald-900/8 bg-white p-6 shadow-sm shadow-emerald-950/5">
            <h3 class="font-display text-lg tracking-wide text-emerald-950">{m.title}</h3>
            <p class="prose-body mt-2 text-sm leading-relaxed text-emerald-950/70">
              {m.href ? (
                <a href={m.href} target="_blank" rel="noopener noreferrer" class="text-emerald-700 underline underline-offset-2">
                  {m.description}
                </a>
              ) : (
                m.description
              )}
            </p>
          </div>
        ))}
      </div>
      <div class="mt-10 flex flex-wrap gap-4">
        <Button href="https://www.paypal.com/us/fundraiser/charity/1573815" external>Give via PayPal Giving Fund</Button>
        <Button href="/contact" variant="ghost">Ask a Question</Button>
      </div>
    </div>
  </section>

  <section class="py-20">
    <div class="mx-auto max-w-6xl px-5">
      <SectionHeading eyebrow="Or Give Through Your Masjid" title="Support your local masjid directly" align="left" />
      <p class="prose-body mt-4 max-w-2xl text-sm leading-relaxed text-emerald-950/70">
        Prefer to give through your own masjid? Each partner committee runs its own donation
        page — your zakat still stays local and reaches GAMRC's shared relief efforts.
      </p>
      <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {masjidDonationLinks.map((m) => (
          <a
            href={m.href}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center justify-between rounded-2xl border border-emerald-900/8 bg-white p-5 shadow-sm shadow-emerald-950/5 transition hover:-translate-y-0.5 hover:shadow-md"
          >
            <span class="font-medium text-emerald-950">{m.name}</span>
            <svg class="h-4 w-4 text-emerald-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M7 17 17 7M9 7h8v8" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
