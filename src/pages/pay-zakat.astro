---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import SectionHeading from "../components/SectionHeading.astro";
import ZakatCalculator from "../components/ZakatCalculator.astro";
import Button from "../components/Button.astro";

const methods = [
  {
    title: "Zelle",
    description: "Send your zakat instantly, with no processing fees. Contact us for the recipient details to use.",
  },
  {
    title: "Venmo",
    description: "A quick, familiar way to give from your phone. Reach out via our Contact page for our Venmo handle.",
  },
  {
    title: "Check",
    description: "Prefer to give by mail? We can provide a mailing address for checks made out to GAMRC.",
  },
  {
    title: "Stock Transfer",
    description: "Donating appreciated stock can be a tax-efficient way to give. Contact us for transfer instructions.",
  },
  {
    title: "Company Matching",
    description: "Many employers match charitable gifts — ask your HR team if your donation can be matched.",
  },
  {
    title: "Facebook Donate",
    description: "Give securely online right now through our Facebook fundraiser, linked below.",
  },
];
---

<BaseLayout
  title="Pay Zakat"
  description="Calculate and pay your zakat locally through GAMRC, supporting families across Greater Austin through Zelle, Venmo, check, stock transfer, and more."
>
  <PageHero
    eyebrow="Pay Zakat"
    title="Give with confidence, right here in Austin"
    description="Every dollar of zakat given to GAMRC is coordinated with our partner masajid and directed to families across Greater Austin facing real, urgent need."
  />

  <section class="mx-auto max-w-4xl px-5 py-20">
    <SectionHeading eyebrow="Zakat Calculator" title="Estimate what you owe" />
    <p class="prose-body mt-4 text-sm leading-relaxed text-emerald-950/70">
      This calculator uses the silver standard for nisab, a commonly used and more cautious
      threshold. It's meant as a helpful estimate only — for a precise ruling on your specific
      situation, please consult a knowledgeable scholar.
    </p>
    <div class="mt-8">
      <ZakatCalculator />
    </div>
  </section>

  <section class="bg-emerald-50/60 py-20">
    <div class="mx-auto max-w-6xl px-5">
      <SectionHeading eyebrow="Ways to Give" title="Choose the method that works for you" />
      <div class="mt-10 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {methods.map((m) => (
          <div class="rounded-2xl border border-emerald-900/8 bg-white p-6 shadow-sm shadow-emerald-950/5">
            <h3 class="font-display text-lg tracking-wide text-emerald-950">{m.title}</h3>
            <p class="prose-body mt-2 text-sm leading-relaxed text-emerald-950/70">{m.description}</p>
          </div>
        ))}
      </div>
      <div class="mt-10 flex flex-wrap gap-4">
        <Button href="https://www.facebook.com/donate/906668713698002/" external>Give on Facebook</Button>
        <Button href="/contact" variant="ghost">Ask a Question</Button>
      </div>
    </div>
  </section>
</BaseLayout>
