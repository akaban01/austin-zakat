---
interface Props {
  eyebrow?: string;
  title: string;
  align?: "left" | "center";
  class?: string;
}

const { eyebrow, title, align = "left", class: className = "" } = Astro.props;
---

<div class:list={["max-w-2xl", align === "center" ? "mx-auto text-center" : "", className]}>
  {eyebrow && (
    <p class="mb-3 flex items-center gap-2 text-xs font-semibold uppercase tracking-[0.2em] text-gold-600" class:list={[align === "center" ? "justify-center" : ""]}>
      <span class="h-px w-6 bg-gold-400"></span>
      {eyebrow}
    </p>
  )}
  <h2 class="font-display text-3xl leading-tight tracking-wide text-emerald-950 sm:text-4xl">
    {title}
  </h2>
</div>
